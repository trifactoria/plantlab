{
  "name": "plantlab",
  "version": "0.1.0",
  "private": true,
  "bin": {
    "plantlab": "./bin/plantlab"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "camera:capture": "tsx scripts/camera-capture.ts",
    "camera:list": "tsx scripts/camera-list.ts",
    "camera:watch": "tsx scripts/camera-watch.ts",
    "camera:service": "tsx scripts/camera-service.ts",
    "backup": "bin/plantlab backup create",
