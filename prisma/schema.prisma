generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Project {
  id                        String    @id @default(cuid())
  name                      String
  description               String?
  gridWidth                 Int
  gridHeight                Int
  photoIntervalMinutes      Int
  captureStartAt            DateTime  @default(now())
  captureEnabled            Boolean   @default(false)
  timeZone                  String    @default("America/New_York")
  captureWindowEnabled      Boolean   @default(false)
  captureWindowStartMinutes Int?
  captureWindowEndMinutes   Int?
  isTestProject             Boolean   @default(false)
  plantedAt                 DateTime?
  localPhotoDirectory       String
  cameraDevice              String?
  cameraName                String?
  cameraStableId            String?
  cameraProfileId           String?
  // Project lifecycle metadata only (see src/lib/projectLifecycle.ts for
  // the allowed values and validation) - purely informational today, the
  // foundation for future backup/publication workflows. Nullable so every
  // existing project migrates safely with zero behavior change: null is
  // treated identically to "ACTIVE" by application code, never enforced
  // or auto-transitioned by this task.
  lifecycleState            String?
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  plants        Plant[]
  photos        Photo[]
  events        PlantEvent[]
  milestones    ProjectMilestone[]
  captureRuns   CaptureRun[]
  sensorBindings ProjectSensorBinding[]
  cameraProfile CameraProfile?     @relation(fields: [cameraProfileId], references: [id], onDelete: SetNull)
  cropPreset    ProjectCropPreset?
  cropVersions  PlantCropVersion[]
  viewports     ProjectViewport[]
}

// A physical camera/device shared by several projects, each of which claims
// a rectangular ProjectViewport of the frame it captures. Orientation
// (rotation/flip) is applied here, before any project viewport geometry is
// interpreted - width/height below are the TRANSFORMED (post-orientation)
// working dimensions. Independent of direct-project capture (Project.
// cameraDevice etc.) - a project uses one model or the other, never both.
model CaptureSource {
  id                        String   @id @default(cuid())
  name                      String
  cameraDevice              String
  cameraName                String?
  cameraStableId            String?
  cameraProfileId           String?
  // Transformed (post-rotation) working dimensions - what project viewport
  // rectangles are normalized against.
  width                     Int
  height                    Int
  rotation                  Int      @default(0)
  flipHorizontal            Boolean  @default(false)
  flipVertical              Boolean  @default(false)
  captureDirectory          String
  active                    Boolean  @default(true)
  photoIntervalMinutes      Int
  captureStartAt            DateTime @default(now())
  timeZone                  String   @default("America/New_York")
  captureWindowEnabled      Boolean  @default(false)
  captureWindowStartMinutes Int?
  captureWindowEndMinutes   Int?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  cameraProfile  CameraProfile?         @relation(fields: [cameraProfileId], references: [id], onDelete: SetNull)
  sourceCaptures SourceCapture[]
  viewports      ProjectViewport[]
  nodeCameras    NodeCamera[]
  assignments    NodeCameraAssignment[]
  agentJobs      AgentCaptureJob[]

  @@index([cameraDevice])
}

// One full-resolution frame captured from a shared CaptureSource at one
// scheduled interval. Retained in full - never duplicated per project.
// The unique index prevents a retried or overlapping scheduler tick from
// creating a second capture for the same source+slot.
model SourceCapture {
  id              String    @id @default(cuid())
  captureSourceId String
  timestamp       DateTime
  scheduledFor    DateTime?
  originalPath    String
  originalWidth   Int
  originalHeight  Int
  workingWidth    Int
  workingHeight   Int
  pixelFormat     String
  createdAt       DateTime  @default(now())

  // Canonical file metadata (nullable - existing rows and locally-driven
  // camera-service captures don't populate these; a separate backfill can
  // fill them in later). Required for anything ingested through the
  // remote HTTP agent-ingest endpoint - see src/lib/ingest.server.ts.
  //
  // captureId is the caller-supplied idempotency key (a UUID the agent
  // generates once per frame and retries with unchanged) - globally
  // unique, not scoped per captureSourceId, since agent-generated UUIDs
  // are already effectively global. Null for locally-driven captures,
  // which have no external caller to supply one.
  captureId        String? @unique
  sha256           String?
  byteSize         Int?
  mimeType         String?
  originalFilename String?
  // Canonical relative path from the capture-sources data root (see
  // resolveCaptureSourcesDataDir() in paths.server.ts), not an absolute
  // host-specific path - e.g. "<captureSourceId>/2026/07/<captureId>.jpg".
  // Locally-driven captures currently keep using originalPath (an absolute
  // path) instead; storageKey is populated going forward for anything
  // ingested remotely so storage can be relocated without a DB migration.
  storageKey       String?
  // Provenance: "local-camera-service" | "http-agent-ingest" | future
  // values (a Raspberry Pi node, a mobile uploader). Null for existing
  // rows predating this column.
  ingestSource     String?

  captureSource CaptureSource     @relation(fields: [captureSourceId], references: [id], onDelete: Cascade)
  viewports     ProjectViewport[] @relation("ViewportSourceCapture")
  photos        Photo[]

  @@unique([captureSourceId, scheduledFor])
  @@index([captureSourceId, timestamp])
}

// A rectangle of a shared CaptureSource's (transformed) frame assigned to
// one project, beginning at effectiveFrom, until a newer version's
// effectiveFrom takes over. Mirrors PlantCropVersion's versioning rule
// exactly (newest version where effectiveFrom <= capture timestamp) -
// immutable once created, an adjustment always creates a new version.
model ProjectViewport {
  id              String   @id @default(cuid())
  projectId       String
  captureSourceId String
  cropX           Float
  cropY           Float
  cropWidth       Float
  cropHeight      Float
  effectiveFrom   DateTime
  active          Boolean  @default(true)
  sourceCaptureId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  captureSource CaptureSource  @relation(fields: [captureSourceId], references: [id], onDelete: Cascade)
  sourceCapture SourceCapture? @relation("ViewportSourceCapture", fields: [sourceCaptureId], references: [id], onDelete: SetNull)
  photos        Photo[]

  @@index([projectId, effectiveFrom])
  @@index([captureSourceId, effectiveFrom])
}

// Sizing/shape suggestion only, applied when a plant has no crop history yet.
// Never a fixed position - see src/lib/cropVersions.ts. One per project.
model ProjectCropPreset {
  id              String   @id @default(cuid())
  projectId       String   @unique
  width           Float
  height          Float
  aspectRatioMode String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ProjectMilestone {
  id        String   @id @default(cuid())
  projectId String
  key       String
  label     String
  sortOrder Int
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  events  PlantEvent[]

  @@unique([projectId, key])
  @@index([projectId, sortOrder])
}

model ProjectSensorBinding {
  id         String    @id @default(cuid())
  projectId  String
  nodeId     String
  sensorId   String
  label      String?
  role       String    @default("ambient")
  enabled    Boolean   @default(true)
  linkedAt   DateTime  @default(now())
  unlinkedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  project Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  node    PlantLabNode @relation(fields: [nodeId], references: [id], onDelete: Restrict)
  sensor  NodeSensor   @relation(fields: [sensorId], references: [id], onDelete: Restrict)

  @@index([projectId, enabled])
  @@index([sensorId])
  @@index([nodeId])
  @@index([projectId, sensorId, enabled])
}

model Plant {
  id                             String   @id @default(cuid())
  projectId                      String
  name                           String
  tags                           String?
  notes                          String?
  gridX                          Int
  gridY                          Int
  visualAspectRatio              String?
  startedAt                      DateTime @default(now())
  startLabel                     String   @default("Added to project")
  // Whether newly created project photos automatically receive this plant's
  // active crop version. Defaults true so existing plants keep today's
  // behavior; a plant with no crop version yet simply has nothing to
  // materialize regardless of this flag.
  automaticCropAssignmentEnabled Boolean  @default(true)
  createdAt                      DateTime @default(now())
  updatedAt                      DateTime @updatedAt

  project       Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  events        PlantEvent[]
  photoCrops    PlantPhotoCrop[]
  cropVersions  PlantCropVersion[]
  harvestResult PlantHarvestResult?

  @@unique([projectId, gridX, gridY])
  @@index([projectId])
}

// A crop rectangle to use for this plant beginning at effectiveFrom, until a
// newer version's effectiveFrom takes over. See src/lib/cropVersions.ts for
// resolution order (newest version where effectiveFrom <= photo.timestamp).
// Immutable once created - an adjustment always creates a new version rather
// than editing an old one, so earlier PlantPhotoCrop rows never need to
// change meaning retroactively.
model PlantCropVersion {
  id              String   @id @default(cuid())
  plantId         String
  projectId       String
  cropX           Float
  cropY           Float
  cropWidth       Float
  cropHeight      Float
  aspectRatioMode String
  effectiveFrom   DateTime
  sourcePhotoId   String?
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  plant             Plant            @relation(fields: [plantId], references: [id], onDelete: Cascade)
  project           Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sourcePhoto       Photo?           @relation(fields: [sourcePhotoId], references: [id], onDelete: SetNull)
  materializedCrops PlantPhotoCrop[]

  @@index([plantId, effectiveFrom])
  @@index([projectId])
}

model Photo {
  id              String   @id @default(cuid())
  projectId       String
  filename        String
  path            String
  timestamp       DateTime
  notes           String?
  // Optional provenance when this photo was derived from a shared
  // CaptureSource's frame via a ProjectViewport, rather than captured
  // directly by the project or uploaded/scanned. Null for every other path.
  sourceCaptureId String?
  viewportId      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  project            Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  events             PlantEvent[]
  captureRuns        CaptureRun[]
  plantCrops         PlantPhotoCrop[]
  cropVersionSources PlantCropVersion[]
  sourceCapture      SourceCapture?     @relation(fields: [sourceCaptureId], references: [id], onDelete: SetNull)
  viewport           ProjectViewport?   @relation(fields: [viewportId], references: [id], onDelete: SetNull)

  @@unique([projectId, path])
  @@index([projectId, timestamp])
  @@index([sourceCaptureId])
  @@index([viewportId])
}

model PlantEvent {
  id          String   @id @default(cuid())
  projectId   String
  plantId     String
  photoId     String?
  milestoneId String?
  // "origin" | "observation". Origin is the single system-created "Added to
  // project" event per plant; see src/lib/experiment.ts for the constants and
  // guards. A partial unique index (see migration) enforces at most one
  // origin event per plant at the database level.
  kind        String   @default("observation")
  type        String
  notes       String?
  timestamp   DateTime
  cropX       Float?
  cropY       Float?
  cropWidth   Float?
  cropHeight  Float?
  createdAt   DateTime @default(now())

  project   Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  plant     Plant             @relation(fields: [plantId], references: [id], onDelete: Cascade)
  photo     Photo?            @relation(fields: [photoId], references: [id], onDelete: SetNull)
  milestone ProjectMilestone? @relation(fields: [milestoneId], references: [id], onDelete: SetNull)

  @@index([projectId, timestamp])
  @@index([plantId, timestamp])
  @@index([photoId])
  @@index([milestoneId])
}

model PlantHarvestResult {
  id              String   @id @default(cuid())
  plantId         String   @unique
  harvestedAt     DateTime
  rootWeightGrams Float?
  rootDiameterMm  Float?
  rootLengthMm    Float?
  split           Boolean  @default(false)
  bolted          Boolean  @default(false)
  damaged         Boolean  @default(false)
  acceptable      Boolean  @default(true)
  flavorScore     Int?
  selectedForSeed Boolean  @default(false)
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  plant Plant @relation(fields: [plantId], references: [id], onDelete: Cascade)
}

model CameraProfile {
  id             String   @id @default(cuid())
  name           String
  cameraDevice   String
  cameraName     String?
  cameraStableId String?
  width          Int
  height         Int
  inputFormat    String
  controlsJson   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  projects       Project[]
  captureSources CaptureSource[]

  @@index([cameraDevice])
}

// status: "running" | "success" | "failed" | "skipped"
model CaptureRun {
  id           String    @id @default(cuid())
  projectId    String
  scheduledFor DateTime
  startedAt    DateTime?
  completedAt  DateTime?
  status       String
  photoId      String?
  errorMessage String?
  cameraDevice String?
  createdAt    DateTime  @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  photo   Photo?  @relation(fields: [photoId], references: [id], onDelete: SetNull)

  @@index([projectId, scheduledFor])
  @@index([status])
}

// One saved crop rectangle for one plant within one project photo, used to
// build a plant's visual history without needing a new photo capture.
//
// createdMethod is this row's provenance. Historical values: "manual",
// "propagated" (old bulk-copy tool, src/lib/plantPhotoCropPropagation.ts).
// New values added by the crop-version system, src/lib/cropVersions.ts:
// "initial_version" (materialized when a plant's first crop version was
// created), "active_version" (materialized automatically for a new photo
// from the plant's active version), "repaired" (missing-frame repair),
// "manual_adjusted" (edited directly on one photo, detached from any
// version's automatic regeneration).
model PlantPhotoCrop {
  id            String   @id @default(cuid())
  plantId       String
  photoId       String
  cropX         Float
  cropY         Float
  cropWidth     Float
  cropHeight    Float
  sourceCropId  String?
  createdMethod String   @default("manual")
  cropVersionId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  plant       Plant             @relation(fields: [plantId], references: [id], onDelete: Cascade)
  photo       Photo             @relation(fields: [photoId], references: [id], onDelete: Cascade)
  cropVersion PlantCropVersion? @relation(fields: [cropVersionId], references: [id], onDelete: SetNull)

  @@unique([plantId, photoId])
  @@index([plantId])
  @@index([cropVersionId])
  @@index([photoId])
  @@index([sourceCropId])
}

// Single row (id "capture-service") tracking the long-running capture service process.
model ServiceStatus {
  id            String   @id
  name          String
  startedAt     DateTime
  lastHeartbeat DateTime
  pid           Int?
  hostname      String?
  version       String?
  lastError     String?
  updatedAt     DateTime @updatedAt
}

// A coordinator-side record for another PlantLab machine. This is additive
// deployment metadata only; it never stores the canonical project database
// path, raw credentials, or local photo paths from the node.
model PlantLabNode {
  id                          String    @id @default(cuid())
  name                        String    @unique
  hostname                    String?
  role                        String
  status                      String    @default("enrolled")
  operatingSystem             String?
  architecture                String?
  softwareVersion             String?
  coordinatorUrl              String?
  lastHeartbeatAt             DateTime?
  /// JSON array of capability strings - see src/lib/operations/capabilities.ts. Additive; never role-exclusive.
  capabilitiesJson            String    @default("[]")
  /// "node" (full TypeScript agent) or "python-edge" (lightweight edge agent) - see edge-agent/. Null until the first heartbeat reports it.
  runtime                     String?
  /// The agent protocol version this node last reported - see docs/AGENT_PROTOCOL.md.
  protocolVersion             String?
  /// Last time this node sent a camera inventory report to the coordinator.
  lastInventoryAt             DateTime?
  /// Set by the coordinator CLI/UI to ask the agent to send inventory immediately on its next poll.
  inventoryRefreshRequestedAt DateTime?
  /// Set by the node detail page's "Refresh power state" action to ask the agent to re-upload outlet state immediately, mirroring inventoryRefreshRequestedAt.
  powerStateRefreshRequestedAt DateTime?
  /// Coordinator-authored desired sensor config revision. Null means this node has not joined the desired/applied config protocol yet.
  desiredSensorConfigRevision Int?
  /// Last sensor config revision the edge explicitly applied.
  appliedSensorConfigRevision Int?
  /// applied | rejected | unknown. Kept on the node for fast summaries; detailed history lives in NodeSensorConfigRevision.
  appliedSensorConfigStatus   String?
  appliedSensorConfigError    String?
  sensorConfigUpdatedAt       DateTime?
  createdAt                   DateTime  @default(now())
  updatedAt                   DateTime  @updatedAt

  credentials       NodeCredential[]
  cameras           NodeCamera[]
  cameraEndpoints   NodeCameraEndpoint[]
  cameraRepairAudit NodeCameraRepairAudit[]
  sensors           NodeSensor[]
  sensorConfigRevisions NodeSensorConfigRevision[]
  outlets           NodeOutlet[]
  powerCommands      PowerCommand[]
  powerSchedules     PowerSchedule[]
  sensorReadings     SensorReading[]
  sensorDiagnostics  SensorDiagnostic[]
  sensorTestCommands SensorTestCommand[]
  projectSensorBindings ProjectSensorBinding[]
  assignments        NodeCameraAssignment[]
  jobs               AgentCaptureJob[]

  @@index([role])
  @@index([lastHeartbeatAt])
  @@index([desiredSensorConfigRevision])
  @@index([appliedSensorConfigRevision])
}

// A persistent daily on/off schedule for a power outlet (fans/lights).
// Ticked by PowerScheduler (src/lib/operations/powerSchedule.ts) from the
// same long-running process as the capture schedulers (scripts/camera-service.ts)
// so it survives coordinator restarts and browser closure. Each firing goes
// through the normal PowerCommand queue - the scheduler never talks to Kasa
// directly. lastRunDateKey (a "yyyy-LL-dd" string in timeZone) is the
// restart-safe idempotency guard: a schedule fires at most once per local day.
model PowerSchedule {
  id             String    @id @default(cuid())
  nodeId         String
  outletKey      String
  action         String
  /// 24h local time, "HH:MM".
  timeOfDay      String
  /// Comma-separated days of week, 0=Sunday..6=Saturday. Defaults to every day.
  daysOfWeek     String    @default("0,1,2,3,4,5,6")
  timeZone       String    @default("America/New_York")
  label          String?
  enabled        Boolean   @default(true)
  lastRunDateKey String?
  lastRunAt      DateTime?
  lastRunStatus  String?
  lastRunError   String?
  /// PowerCommand.id created by the most recent firing of this schedule.
  /// Plain id reference (no Prisma relation) rather than timestamp-guessing -
  /// lets the schedule API/UI show the command's real, live lifecycle status
  /// (pending/claimed/succeeded/failed/expired/cancelled) instead of a
  /// hardcoded "queued". Reset to null whenever an edit changes what the
  /// schedule would actually do - see updatePowerSchedule().
  lastCommandId  String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  node PlantLabNode @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  @@index([nodeId, outletKey])
  @@index([lastCommandId])
  @@index([nodeId, enabled])
}

model NodeOutlet {
  id                   String   @id @default(cuid())
  nodeId               String
  key                  String
  name                 String
  provider             String
  providerAlias        String
  enabled              Boolean  @default(true)
  /// Explicit behavior policy for command/schedule validation. Supported
  /// values today: "normal" and "pulse-only". Do not infer behavior from key.
  behavior             String   @default("normal")
  safetyClass          String   @default("switch")
  actualState          Boolean?
  stateObservedAt      DateTime?
  available            Boolean  @default(false)
  lastErrorCode        String?
  lastErrorMessage     String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  node     PlantLabNode  @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  commands PowerCommand[]

  @@unique([nodeId, key])
  @@index([nodeId])
  @@index([available])
  @@index([behavior])
}

model PowerCommand {
  id              String    @id @default(cuid())
  nodeId          String
  outletId        String?
  outletKey       String
  action          String
  durationSeconds Int?
  status          String    @default("pending")
  requestedAt     DateTime  @default(now())
  availableAt     DateTime  @default(now())
  claimedAt       DateTime?
  completedAt     DateTime?
  expiresAt       DateTime
  attemptCount    Int       @default(0)
  idempotencyKey  String?
  errorCode       String?
  errorMessage    String?
  actualState     Boolean?
  stateObservedAt DateTime?
  requestedBy     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  node   PlantLabNode @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  outlet NodeOutlet?  @relation(fields: [outletId], references: [id], onDelete: SetNull)

  @@unique([nodeId, idempotencyKey])
  @@index([nodeId, status, availableAt])
  @@index([nodeId, outletKey, status])
  @@index([expiresAt])
}

model NodeSensor {
  id                    String    @id @default(cuid())
  nodeId                String
  key                   String
  name                  String
  type                  String
  gpio                  Int?
  placement             String?
  enabled               Boolean   @default(true)
  configuredActive      Boolean   @default(true)
  retiredAt             DateTime?
  desiredConfigRevision Int?
  appliedConfigRevision Int?
  firstSeenAt           DateTime  @default(now())
  lastSeenAt            DateTime  @default(now())
  lastAttemptAt         DateTime?
  lastAcceptedAt        DateTime?
  latestClassification  String?
  latestTemperatureC    Float?
  latestHumidityPct     Float?
  consecutiveFailures   Int       @default(0)
  consecutiveRejects    Int       @default(0)
  lastDiagnosticCode    String?
  lastDiagnosticMessage String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  node        PlantLabNode       @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  readings    SensorReading[]
  diagnostics SensorDiagnostic[]
  projectBindings ProjectSensorBinding[]

  @@unique([nodeId, key])
  @@index([nodeId])
  @@index([lastSeenAt])
  @@index([latestClassification])
  @@index([nodeId, configuredActive])
  @@index([retiredAt])
}

model SensorReading {
  id           String   @id @default(cuid())
  sensorId     String
  nodeId       String
  eventId      String
  capturedAt   DateTime
  temperatureC Float
  humidityPct  Float
  receivedAt   DateTime @default(now())

  sensor NodeSensor   @relation(fields: [sensorId], references: [id], onDelete: Restrict)
  node   PlantLabNode @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  @@unique([nodeId, eventId])
  @@index([sensorId, capturedAt])
  @@index([nodeId, capturedAt])
  @@index([nodeId, sensorId, capturedAt])
}

model SensorDiagnostic {
  id             String   @id @default(cuid())
  sensorId       String
  nodeId         String
  eventId        String
  capturedAt     DateTime
  classification String
  temperatureC   Float?
  humidityPct    Float?
  code           String?
  message        String?
  /// Which attempt within a multi-attempt sequence produced this diagnostic
  /// (1-based) - populated by sensor-test attempts; null for ordinary
  /// single-shot continuous telemetry sampling, where the concept doesn't apply.
  attemptNumber  Int?
  /// Driver/backend that produced this event, e.g. "pigpio", "mock" - see edge-agent/plantlab_edge_agent/sensors/.
  driver         String?
  /// BCM GPIO configured at the time of this event. Denormalized from
  /// NodeSensor.gpio so historical diagnostics stay accurate even if a
  /// sensor's GPIO assignment is later reconfigured.
  gpio           Int?
  /// Wall-clock duration of the read attempt in milliseconds, when known.
  durationMs     Int?
  receivedAt     DateTime @default(now())

  sensor NodeSensor   @relation(fields: [sensorId], references: [id], onDelete: Restrict)
  node   PlantLabNode @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  @@unique([nodeId, eventId])
  @@index([sensorId, capturedAt])
  @@index([nodeId, capturedAt])
  @@index([classification])
}

// A bounded, authenticated remote diagnostic command - "run N read attempts
// against this sensor and report the results," equivalent in intent to the
// local `plantlab-edge sensor test <key> --attempts N --interval S` CLI
// command, but dispatched from the coordinator browser through the normal
// agent command-queue protocol (mirrors PowerCommand's lifecycle exactly -
// see src/lib/operations/powerProtocol.ts and sensorTestProtocol.ts).
// "running" (absent from PowerCommand) exists because a sensor test takes
// several seconds to tens of seconds to execute, unlike a near-instant
// power toggle - the UI needs a distinct state between "claimed" and done.
model SensorTestCommand {
  id                String    @id @default(cuid())
  nodeId            String
  sensorKey         String
  status            String    @default("pending") // pending | claimed | running | succeeded | failed | expired | cancelled
  attemptsRequested Int
  intervalSeconds   Float
  requestedAt       DateTime  @default(now())
  availableAt       DateTime  @default(now())
  claimedAt         DateTime?
  startedAt         DateTime?
  completedAt       DateTime?
  expiresAt         DateTime
  attemptCount      Int       @default(0)
  idempotencyKey    String?
  requestedBy       String?
  /// Attempts actually executed, accepted count, failed count, and a
  /// structured per-attempt array (classification/code/message/reading) -
  /// JSON since this is opaque test-result detail read as a whole, not a
  /// commonly-queried field (see AGENTS.md "use structured fields for
  /// common searchable concepts" - the searchable concepts here are
  /// sensorKey/status/requestedAt, which are already plain columns).
  attemptsCompleted Int?
  acceptedCount     Int?
  failedCount       Int?
  finalPass         Boolean?
  effectiveDriver   String?
  configuredGpio    Int?
  attemptsJson      String?
  errorCode         String?
  errorMessage      String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  node PlantLabNode @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  @@unique([nodeId, idempotencyKey])
  @@index([nodeId, sensorKey, status])
  @@index([nodeId, status, availableAt])
  @@index([expiresAt])
}

model NodeCredential {
  id             String    @id @default(cuid())
  nodeId         String
  credentialHash String    @unique
  createdAt      DateTime  @default(now())
  lastUsedAt     DateTime?
  revokedAt      DateTime?

  node PlantLabNode @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  @@index([nodeId])
  @@index([revokedAt])
}

model NodeCamera {
  id                   String   @id @default(cuid())
  nodeId               String
  stableId             String
  legacyStableId       String?
  devicePath           String
  name                 String?
  vendorId             String?
  productId            String?
  serial               String?
  physicalPath         String?
  usbPath              String?
  usbPort              String?
  alternateDevicesJson String?
  identityEvidenceJson String?
  formatsJson          String?
  available            Boolean  @default(true)
  enabled              Boolean  @default(true)
  retiredAt            DateTime?
  lastSeenAt           DateTime @default(now())
  captureSourceId      String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  node          PlantLabNode           @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  captureSource CaptureSource?         @relation(fields: [captureSourceId], references: [id], onDelete: SetNull)
  assignments   NodeCameraAssignment[]
  endpoints     NodeCameraEndpoint[]
  repairAudit   NodeCameraRepairAudit[]

  @@unique([nodeId, stableId])
  @@index([nodeId])
  @@index([captureSourceId])
  @@index([nodeId, available])
  @@index([retiredAt])
}

model NodeCameraEndpoint {
  id                   String   @id @default(cuid())
  nodeId               String
  nodeCameraId         String?
  stableId             String
  devicePath           String
  name                 String?
  vendorId             String?
  productId            String?
  serial               String?
  physicalPath         String?
  usbPath              String?
  usbPort              String?
  alternateDevicesJson String?
  formatsJson          String?
  available            Boolean  @default(true)
  observedAt           DateTime @default(now())
  unavailableAt        DateTime?
  confidence           String   @default("reported-stable-id")
  evidenceJson         String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  node       PlantLabNode @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  nodeCamera NodeCamera?  @relation(fields: [nodeCameraId], references: [id], onDelete: SetNull)

  @@unique([nodeId, stableId, devicePath])
  @@index([nodeId, available])
  @@index([nodeCameraId, observedAt])
  @@index([nodeId, stableId])
}

model NodeCameraRepairAudit {
  id              String   @id @default(cuid())
  nodeId          String
  nodeCameraId    String?
  operation       String
  status          String
  requestedBy     String?
  previousStateJson String?
  nextStateJson   String?
  evidenceJson    String?
  errorMessage    String?
  createdAt       DateTime @default(now())

  node       PlantLabNode @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  nodeCamera NodeCamera?  @relation(fields: [nodeCameraId], references: [id], onDelete: SetNull)

  @@index([nodeId, createdAt])
  @@index([nodeCameraId])
  @@index([operation, status])
}

model NodeCameraAssignment {
  id              String   @id @default(cuid())
  nodeId          String
  nodeCameraId    String
  captureSourceId String
  name            String
  width           Int
  height          Int
  inputFormat     String   @default("mjpeg")
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  node          PlantLabNode      @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  nodeCamera    NodeCamera        @relation(fields: [nodeCameraId], references: [id], onDelete: Cascade)
  captureSource CaptureSource     @relation(fields: [captureSourceId], references: [id], onDelete: Cascade)
  jobs          AgentCaptureJob[]

  @@unique([nodeId, nodeCameraId, captureSourceId])
  @@index([nodeId])
  @@index([captureSourceId])
  @@index([active])
}

model AgentCaptureJob {
  id              String    @id @default(cuid())
  nodeId          String
  assignmentId    String
  captureSourceId String
  status          String    @default("queued")
  scheduledFor    DateTime?
  requestedAt     DateTime  @default(now())
  claimedAt       DateTime?
  completedAt     DateTime?
  captureId       String?   @unique
  sourceCaptureId String?
  errorMessage    String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  node          PlantLabNode         @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  assignment    NodeCameraAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  captureSource CaptureSource        @relation(fields: [captureSourceId], references: [id], onDelete: Cascade)

  @@index([nodeId, status, requestedAt])
  @@index([assignmentId])
  @@index([captureSourceId])
  @@index([captureSourceId, scheduledFor])
}

model NodeSensorConfigRevision {
  id              String    @id @default(cuid())
  nodeId          String
  revision        Int
  requestedAt     DateTime  @default(now())
  requestedBy     String?
  source          String    @default("coordinator")
  validationStatus String   @default("valid")
  applyStatus     String    @default("pending") // pending | applied | rejected
  appliedAt       DateTime?
  rejectedAt      DateTime?
  rejectionReason String?
  entriesJson     String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  node PlantLabNode @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  @@unique([nodeId, revision])
  @@index([nodeId, applyStatus])
  @@index([requestedAt])
}
