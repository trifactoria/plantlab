generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Project {
  id                    String   @id @default(cuid())
  name                  String
  description           String?
  gridWidth             Int
  gridHeight            Int
  photoIntervalMinutes  Int
  captureStartAt        DateTime @default(now())
  captureEnabled        Boolean  @default(false)
  plantedAt             DateTime?
  localPhotoDirectory   String
  cameraDevice          String?
  cameraName            String?
  cameraStableId        String?
  cameraProfileId       String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  plants        Plant[]
  photos        Photo[]
  events        PlantEvent[]
  captureRuns   CaptureRun[]
  cameraProfile CameraProfile? @relation(fields: [cameraProfileId], references: [id], onDelete: SetNull)
}

model Plant {
  id         String   @id @default(cuid())
  projectId  String
  name       String
  tags       String?
  notes      String?
  gridX      Int
  gridY      Int
  startedAt  DateTime @default(now())
  startLabel String   @default("Added to project")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  project Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  events  PlantEvent[]

  @@unique([projectId, gridX, gridY])
  @@index([projectId])
}

model Photo {
  id        String   @id @default(cuid())
  projectId String
  filename  String
  path      String
  timestamp DateTime
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  events      PlantEvent[]
  captureRuns CaptureRun[]

  @@unique([projectId, path])
  @@index([projectId, timestamp])
}

model PlantEvent {
  id         String   @id @default(cuid())
  projectId  String
  plantId    String
  photoId    String?
  type       String
  notes      String?
  timestamp  DateTime
  cropX      Float?
  cropY      Float?
  cropWidth  Float?
  cropHeight Float?
  createdAt  DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  plant   Plant   @relation(fields: [plantId], references: [id], onDelete: Cascade)
  photo   Photo?  @relation(fields: [photoId], references: [id], onDelete: SetNull)

  @@index([projectId, timestamp])
  @@index([plantId, timestamp])
  @@index([photoId])
}

model CameraProfile {
  id             String   @id @default(cuid())
  name           String
  cameraDevice   String
  cameraName     String?
  cameraStableId String?
  width          Int
  height         Int
  inputFormat    String
  controlsJson   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  projects Project[]

  @@index([cameraDevice])
}

// status: "running" | "success" | "failed" | "skipped"
model CaptureRun {
  id           String    @id @default(cuid())
  projectId    String
  scheduledFor DateTime
  startedAt    DateTime?
  completedAt  DateTime?
  status       String
  photoId      String?
  errorMessage String?
  cameraDevice String?
  createdAt    DateTime  @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  photo   Photo?  @relation(fields: [photoId], references: [id], onDelete: SetNull)

  @@index([projectId, scheduledFor])
  @@index([status])
}

// Single row (id "capture-service") tracking the long-running capture service process.
model ServiceStatus {
  id            String   @id
  name          String
  startedAt     DateTime
  lastHeartbeat DateTime
  pid           Int?
  hostname      String?
  version       String?
  lastError     String?
  updatedAt     DateTime @updatedAt
}
