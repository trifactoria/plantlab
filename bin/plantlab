#!/usr/bin/env node
// Thin launcher: spawns tsx against the real TypeScript CLI entry point
// (src/cli/index.ts). This repository never compiles a build step for its
// operational tooling (scripts/*.ts already all run this way via
// "tsx scripts/x.ts" in package.json) - this keeps the CLI on the same,
// already-established convention rather than introducing a second one.
"use strict";

const path = require("node:path");
const { spawnSync } = require("node:child_process");

const tsxCli = require.resolve("tsx/cli");
const cliEntry = path.join(__dirname, "..", "src", "cli", "index.ts");

const result = spawnSync(process.execPath, [tsxCli, cliEntry, ...process.argv.slice(2)], {
  stdio: "inherit",
  cwd: process.cwd(),
});

if (result.error) {
  console.error(`Could not launch the PlantLab CLI: ${result.error.message}`);
  process.exit(1);
}

process.exit(result.status ?? 1);
